# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Open Telegram and message @BotFather
# 2. Send /newbot, follow the prompts, copy the token it gives you
TELEGRAM_BOT_TOKEN=123456789:AAF_your_bot_token_here

# Your personal Telegram chat ID (numeric).
# How to find it: start the bot, send it any message, check the server logs —
# it prints "Message from chat_id=XXXXXXX" for any unrecognized sender.
# Paste that number here, then restart the server.
TELEGRAM_CHAT_ID=123456789

# ─── Google Sheets ────────────────────────────────────────────────────────────
# The spreadsheet ID from the sheet URL:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here
# Either a file path to the service account JSON key, OR the raw JSON content inline.
# File path example:   GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# Inline JSON example: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── News API ────────────────────────────────────────────────────────────────
# Supported providers: "newsapi" or "gnews"
#   newsapi → get a free key at https://newsapi.org/register (free tier: 100 req/day)
#   gnews   → get a free key at https://gnews.io (free tier: 100 req/day)
NEWS_API_PROVIDER=newsapi
NEWS_API_KEY=your_news_api_key_here

# ─── Scheduling ──────────────────────────────────────────────────────────────
# Cron expressions for the two scheduled jobs.
# Timezone must be a valid tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York
MORNING_DIGEST_TIME=0 8 * * *
EVENING_CHECKIN_TIME=0 21 * * *
NIGHTLY_REMINDER_TIME=50 23 * * *

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
